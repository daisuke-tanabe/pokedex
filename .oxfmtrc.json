{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "insertFinalNewline": true,
  "experimentalSortImports": {
    "groups": ["builtin", "external", "internal", ["parent", "sibling"], "index"],
    "internalPattern": ["@/"],
    "newlinesBetween": true
  }
}
