{
  "name": "@pokedex/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.development --env-file-if-exists=../../.env.local src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "oxlint --type-aware .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "1.19.14",
    "@hono/valibot-validator": "0.5.3",
    "@pokedex/contracts": "workspace:*",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.18",
    "postgres": "3.4.9",
    "valibot": "1.4.0"
  },
  "devDependencies": {
    "@types/node": "24.12.3",
    "drizzle-kit": "0.31.10",
    "tsx": "4.21.0",
    "vitest": "catalog:"
  }
}
