{
  "name": "@pokedex/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.development --env-file-if-exists=../../.env.local src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "oxlint --type-aware .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "seed": "tsx --env-file=../../.env.development --env-file-if-exists=../../.env.local ./src/db/seed/seed.ts",
    "db:reset": "supabase db reset && pnpm seed"
  },
  "dependencies": {
    "@hono/node-server": "2.0.3",
    "@hono/valibot-validator": "0.6.1",
    "@pokedex/contracts": "workspace:*",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.21",
    "postgres": "3.4.9",
    "valibot": "1.4.0"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "drizzle-kit": "0.31.10",
    "tsx": "4.22.3",
    "vitest": "catalog:"
  }
}
